{
    "name": "zoon/psalm-fixer",
    "description": "Automatic fixer for Psalm static analysis issues via AST transformations",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^6.0|^7.0",
        "phpstan/phpdoc-parser": "^1.0|^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "vimeo/psalm": "^6.15"
    },
    "autoload": {
        "psr-4": {
            "PsalmFixer\\": "src/PsalmFixer/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PsalmFixer\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/psalm-fixer"
    ],
    "config": {
        "sort-packages": true
    }
}
